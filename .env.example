# Make.com webhook URL — server-side only, never exposed to browser
# Used by src/pages/api/lead.ts (requires non-static hosting, see README)
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/YOUR_WEBHOOK_ID

# Lead endpoint URL — override when deploying API to a separate service
# (e.g., a Cloudflare Worker) while keeping the static site on GitHub Pages
# Leave empty to use the built-in /api/lead route (requires Netlify/CF Pages)
PUBLIC_LEAD_ENDPOINT=

# GTM container ID (existing: GTM-TGTKG654 — confirm before launch)
PUBLIC_GTM_ID=GTM-TGTKG654

# Site domain for canonical URLs and hreflang
PUBLIC_SITE_URL=https://renovpro.be
