---
import type { Locale } from '../lib/i18n';
import { t, altLocale, localePath } from '../lib/i18n';

interface Props {
  locale: Locale;
  page?: string;
}

const { locale, page = '' } = Astro.props;
const tr = t(locale);
const other = altLocale(locale);
const otherPath = localePath(other, page);
---

<header class="header">
  <div class="wrap header__inner">
    <a class="logo" href={localePath(locale)} aria-label="Renov Pro — home">
      <span class="logo__renov">Renov</span>
      <span class="logo__pro">Pro</span>
    </a>

    <nav class="mainnav" aria-label="Hoofdnavigatie">
      <a href={`${localePath(locale)}#diensten`}>{tr.nav.diensten}</a>
      <a href={`${localePath(locale)}#aanpak`}>{tr.nav.aanpak}</a>
      <a href={`${localePath(locale)}#werkwijze`}>{tr.nav.werkwijze}</a>
      <a href={`${localePath(locale)}#realisaties`}>{tr.nav.realisaties}</a>
      <a href={`${localePath(locale)}#contact`}>{tr.nav.contact}</a>
    </nav>

    <div class="header__actions">
      <a class="lang-toggle" href={otherPath} aria-label={`Switch to ${other.toUpperCase()}`}>
        {other.toUpperCase()}
      </a>
      <a class="btn-primary btn-primary--sm" href={localePath(locale, 'studio')}>
        {tr.nav.offerte} →
      </a>
    </div>

    <button class="burger" aria-label="Menu openen" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav aria-label="Mobiele navigatie">
      <a href={`${localePath(locale)}#diensten`}>{tr.nav.diensten}</a>
      <a href={`${localePath(locale)}#aanpak`}>{tr.nav.aanpak}</a>
      <a href={`${localePath(locale)}#werkwijze`}>{tr.nav.werkwijze}</a>
      <a href={`${localePath(locale)}#realisaties`}>{tr.nav.realisaties}</a>
      <a href={`${localePath(locale)}#contact`}>{tr.nav.contact}</a>
      <a href={otherPath} class="lang-link">{other.toUpperCase()}</a>
      <a class="btn-primary" href={localePath(locale, 'studio')}>{tr.nav.offerte} →</a>
    </nav>
  </div>
</header>

<style>
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(244, 241, 234, 0.9);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--line);
}

.header__inner {
  display: flex;
  align-items: center;
  gap: var(--space-m);
  height: 64px;
}

.logo {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 400;
  letter-spacing: -0.02em;
  flex-shrink: 0;
}
.logo__renov { color: var(--ink); }
.logo__pro   { color: var(--brass); font-style: italic; }

.mainnav {
  display: flex;
  gap: var(--space-m);
  margin-left: auto;
}
.mainnav a {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--muted);
  transition: color 0.15s;
}
.mainnav a:hover { color: var(--ink); }

.header__actions {
  display: flex;
  align-items: center;
  gap: var(--space-s);
  flex-shrink: 0;
}

.lang-toggle {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--muted);
  padding: 0.4rem 0.6rem;
  border-radius: 8px;
  border: 1px solid var(--line);
  transition: border-color 0.15s, color 0.15s;
}
.lang-toggle:hover { color: var(--ink); border-color: var(--ink); }

.btn-primary--sm {
  font-size: 0.8rem;
  padding: 0.5rem 1rem;
}

.burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.4rem;
  margin-left: auto;
}
.burger span {
  display: block;
  width: 22px;
  height: 1.5px;
  background: var(--ink);
  border-radius: 2px;
  transition: transform 0.25s var(--ease), opacity 0.2s;
}
.burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

.mobile-menu {
  border-top: 1px solid var(--line);
  background: var(--surface);
  padding: var(--space-m);
}
.mobile-menu nav {
  display: flex;
  flex-direction: column;
  gap: var(--space-s);
}
.mobile-menu a {
  font-size: 1rem;
  font-weight: 500;
  color: var(--ink);
  padding: 0.5rem 0;
  border-bottom: 1px solid var(--line);
}
.mobile-menu .lang-link { color: var(--muted); font-size: 0.875rem; }
.mobile-menu .btn-primary { text-align: center; margin-top: var(--space-xs); }

@media (max-width: 860px) {
  .mainnav, .header__actions .lang-toggle, .header__actions .btn-primary { display: none; }
  .burger { display: flex; }
}
</style>

<script>
const burger = document.querySelector('.burger') as HTMLButtonElement;
const menu   = document.getElementById('mobile-menu') as HTMLElement;
burger?.addEventListener('click', () => {
  const open = burger.getAttribute('aria-expanded') === 'true';
  burger.setAttribute('aria-expanded', String(!open));
  menu.hidden = open;
});
// Close on anchor click
menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
  burger.setAttribute('aria-expanded', 'false');
  menu.hidden = true;
}));
</script>
